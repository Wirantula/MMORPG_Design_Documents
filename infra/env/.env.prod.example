# CybaWorld Production Environment Variables
# Copy to .env.prod and fill in real values. NEVER commit the real .env.prod file.

# ── Domain ───────────────────────────────────────────────────
DOMAIN=play.example.com

# ── Node / Server ────────────────────────────────────────────
NODE_ENV=production
SERVER_PORT=1545
LOG_LEVEL=info

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cybaworld
POSTGRES_USER=cybaworld
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT / Auth ───────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Simulation ───────────────────────────────────────────────
WORLD_SEED_ISO=2200-01-01T00:00:00.000Z
TIME_ACCELERATION=30
TICK_INTERVAL_MS=2000
